              let currentPage = 1;
        let totalPages = 1;

        function searchProjects() {

            let searchText = $("#projectSearch").val();
            let searchType = $("#search-dropdown").val();
            let activeProjectsOnly = $("#activeProjectsOnly").is(":checked");

            $("#projectResults").html("Loading...");

            $.ajax({
                url: "/Home/SearchProjects",
                type: "GET",

                data: {
                    query: searchText,
                    type: searchType,
                    filter: activeProjectsOnly,
                    page: currentPage,
                    pageSize: $("#pageSize").val()
                },

                success: function (response) {

                    let html = "";

                    response.data.forEach(function (item) {

                        html += `
                            <div class="result-item" data-id="${item.project}">

                                <strong style="font-size:18px;">
                                    ${item.client}
                                </strong>

                                <br/>

                                <span>
                                    Project Name:
                                    <span style="color:#6f42c1;">
                                        ${item.projectName}
                                    </span>
                                </span>

                            </div>
                        `;
                    });

                            $("#totalCountText").text(
            `Total: ${response.totalCount}`
        );

                    $("#projectResults").html(html);

                    totalPages = Math.ceil(
                        response.totalCount / $("#pageSize").val()
                    );

                    $("#pageInfo").text(
                        `Page ${currentPage} of ${totalPages}`
                    );

                    $("#prevBtn").prop(
                        "disabled",
                        currentPage === 1
                    );

                    $("#nextBtn").prop(
                        "disabled",
                        currentPage === totalPages
                    );
                },

                error: function () {

                    $("#projectResults").html(
                        "Error loading data"
                    );
                }
            });
        }

        $("#projectSearch").on("keypress", function (e) {

            if (e.which === 13) {

                e.preventDefault();

                currentPage = 1;

                searchProjects();
            }
        });

        $("#nextBtn").click(function () {

            if (currentPage < totalPages) {

                currentPage++;

                searchProjects();
            }
        });

        $("#prevBtn").click(function () {

            if (currentPage > 1) {

                currentPage--;

                searchProjects();
            }
        });

        $("#pageSize").change(function () {

            currentPage = 1;

            searchProjects();
        });



        });

